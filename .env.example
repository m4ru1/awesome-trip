# =============================================================================
# Awesome Trip — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [Server] are only needed for the Express backend.
# Variables with defaults work out of the box for local development.
# =============================================================================

# ----- Server [Server] -----
# Port for the Express server (default: 3000)
PORT=3000

# Allowed CORS origins, comma-separated (default: empty = allow all)
# Example: ALLOWED_ORIGINS=https://trip.example.com,https://staging.trip.example.com
ALLOWED_ORIGINS=

# ----- Rate Limiting [Server] -----
# Max GET requests per minute per client (default: 60)
RATE_LIMIT_GET_PER_MIN=60

# Max POST requests per hour per client (default: 10)
RATE_LIMIT_POST_PER_HOUR=10

# ----- Request Limits [Server] -----
# Max request body size in bytes (default: 1048576 = 1MB)
MAX_BODY_SIZE=1048576

# ----- Database [Server] -----
# Path to the SQLite database file (default: ./data/marketplace.db)
DB_PATH=./data/marketplace.db

# ----- Frontend -----
# Base URL for the API server (default: /api)
# VITE_API_BASE=/api
